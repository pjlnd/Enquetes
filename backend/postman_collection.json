{
  "info": {
    "name": "Sistema de Enquetes - API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth - Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Fulano\",\n  \"email\": \"fulano@teste.com\",\n  \"password\": \"123456\"\n}"
        },
        "url": "{{base_url}}/auth/register"
      }
    },
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"fulano@teste.com\",\n  \"password\": \"123456\"\n}"
        },
        "url": "{{base_url}}/auth/login"
      }
    },
    {
      "name": "Auth - Me",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{base_url}}/auth/me"
      }
    },
    {
      "name": "Polls - List",
      "request": { "method": "GET", "url": "{{base_url}}/polls" }
    },
    {
      "name": "Polls - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Qual sua linguagem favorita?\",\n  \"description\": \"Enquete de teste\",\n  \"options\": [\"PHP\", \"JavaScript\", \"Python\"]\n}"
        },
        "url": "{{base_url}}/polls"
      }
    },
    {
      "name": "Polls - Show",
      "request": { "method": "GET", "url": "{{base_url}}/polls/1" }
    },
    {
      "name": "Polls - Update",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Titulo atualizado\"\n}"
        },
        "url": "{{base_url}}/polls/1"
      }
    },
    {
      "name": "Polls - Delete",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{base_url}}/polls/1"
      }
    },
    {
      "name": "Polls - Results",
      "request": { "method": "GET", "url": "{{base_url}}/polls/1/results" }
    },
    {
      "name": "Votes - Cast Vote",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"poll_option_id\": 1\n}"
        },
        "url": "{{base_url}}/polls/1/vote"
      }
    }
  ]
}
